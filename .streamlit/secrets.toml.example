# CareValidate Finance Suite — Streamlit Secrets Template
# Copy this file to .streamlit/secrets.toml and fill in real values.
# secrets.toml is in .gitignore and must NEVER be committed to git.
#
# On Streamlit Cloud: paste these values in the "Secrets" section of your
# app settings (Settings → Secrets).
#
# To generate a password hash:
#   python -c "import hashlib; print(hashlib.sha256(b'YourPassword').hexdigest())"

[credentials]
# username = "sha256_hex_of_password"
david  = "REPLACE_WITH_SHA256_HASH_OF_DAVID_PASSWORD"
connor = "REPLACE_WITH_SHA256_HASH_OF_CONNOR_PASSWORD"
demo   = "REPLACE_WITH_SHA256_HASH_OF_DEMO_PASSWORD"
